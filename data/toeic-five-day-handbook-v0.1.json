{
  "version": "0.1",
  "title": "TOEIC五天邪修手冊",
  "cards": [
    {
      "id": "card-001",
      "category": "總策略",
      "title": "錯題六分類",
      "rule": "每一題只選一個主要錯因：V/G/L/P/T/C。分類的目的，是決定下一步，而不是做漂亮筆記。",
      "examples": [
        "invoice 不會 → V",
        "because / because of 搞混 → G",
        "聽到 fifteen 誤判 fifty → L"
      ],
      "traps": [
        "不要把所有錯題都寫成粗心"
      ]
    },
    {
      "id": "card-002",
      "category": "Part 5 詞性",
      "title": "冠詞／所有格＋____＋名詞",
      "rule": "通常缺形容詞",
      "examples": [
        "an annual report；our new policy"
      ],
      "traps": []
    },
    {
      "id": "card-003",
      "category": "Part 5 詞性",
      "title": "冠詞＋____",
      "rule": "通常缺名詞",
      "examples": [
        "a decision；the expansion"
      ],
      "traps": []
    },
    {
      "id": "card-004",
      "category": "Part 5 詞性",
      "title": "be 動詞＋____",
      "rule": "形容詞或過去分詞，須看語意",
      "examples": [
        "is available；was approved"
      ],
      "traps": []
    },
    {
      "id": "card-005",
      "category": "Part 5 詞性",
      "title": "動詞＋____",
      "rule": "多半是副詞或受詞名詞",
      "examples": [
        "respond promptly；submit an application"
      ],
      "traps": []
    },
    {
      "id": "card-006",
      "category": "Part 5 詞性",
      "title": "____＋形容詞／副詞",
      "rule": "通常缺副詞",
      "examples": [
        "highly effective；very carefully"
      ],
      "traps": []
    },
    {
      "id": "card-007",
      "category": "Part 5 詞性",
      "title": "介系詞＋____",
      "rule": "名詞、代名詞或 V-ing",
      "examples": [
        "after completion；by using"
      ],
      "traps": []
    },
    {
      "id": "card-008",
      "category": "Part 5 動詞",
      "title": "主被動判斷",
      "rule": "先問主詞「做動作」還是「被做」；再決定主動或 be + Vpp。",
      "examples": [
        "The manager approved the plan.",
        "The plan was approved by the manager."
      ],
      "traps": [
        "不要只看到 by 就機械選被動；by Friday 是時間"
      ]
    },
    {
      "id": "card-009",
      "category": "Part 5 連接詞",
      "title": "because 與 because of",
      "rule": "because 後面接完整子句；because of 後面接名詞片語。",
      "examples": [
        "The event was canceled because it rained.",
        "The event was canceled because of the rain."
      ],
      "traps": []
    },
    {
      "id": "card-010",
      "category": "Part 5 連接詞",
      "title": "although 與 despite",
      "rule": "although 接 S+V；despite 接名詞或 V-ing。",
      "examples": [
        "Although demand increased, prices remained stable.",
        "Despite increased demand, prices remained stable."
      ],
      "traps": []
    },
    {
      "id": "card-011",
